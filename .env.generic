RPI3_METEO_DB_PATH=/app/data/weather.db

RPI3_METEO_MQTT_ENABLED=true
RPI3_METEO_MQTT_BROKER=mosquitto
RPI3_METEO_MQTT_PORT=1883
RPI3_METEO_MQTT_AGGREGATED_TOPIC=weather/sensors
RPI3_METEO_MQTT_RAW_TOPIC=weather/sensors/raw
RPI3_METEO_MQTT_CLIENT_ID=rpi3-meteo-ui
RPI3_METEO_MQTT_KEEPALIVE=60
RPI3_METEO_MQTT_QOS=0

RPI3_METEO_LOCATION_LABEL=Exemple de localisation
RPI3_METEO_LATITUDE=
RPI3_METEO_LONGITUDE=
RPI3_METEO_ALTITUDE_M=
